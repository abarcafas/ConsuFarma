<!DOCTYPE html>
<html lang="es">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>MediConsulta — Consultar medicamento</title>

<link rel="stylesheet" href="/public/css/dashboardUser.css">

<link rel="preconnect" href="https://fonts.googleapis.com">

<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="flex flex-col h-screen font-['Nunito',sans-serif]">

<header class="relative z-20 flex items-center justify-between px-4 sm:px-6 py-3
bg-white/92 backdrop-blur border-b border-[#1a7a5e]/10
shadow-[0_2px_16px_rgba(26,122,94,0.08)]">

<div class="flex items-center gap-3">

<button id="sidebar-toggle"
class="sm:hidden w-9 h-9 rounded-xl bg-[#e8f5f0] flex items-center justify-center">

<svg class="w-5 h-5 fill-[#1a7a5e]" viewBox="0 0 24 24">
<path d="M3 6h18M3 12h18M3 18h18" stroke="#1a7a5e" stroke-width="2" stroke-linecap="round" fill="none"/>
</svg>

</button>

<div class="w-10 h-10 bg-gradient-to-br from-[#1a7a5e] to-[#25a87e]
rounded-xl flex items-center justify-center">

<svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
<path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/>
</svg>

</div>

<div>

<h2 class="font-['Playfair_Display',serif] text-lg text-[#135c47]">
MediConsulta
</h2>

<span id="subtituloHeader" class="text-[10px] text-[#5a7a6e] font-bold uppercase">
Asistente de medicamentos
</span>

</div>

</div>

</header>

<div class="flex flex-1 overflow-hidden min-h-0">
<!-- overlay móvil -->

<div id="sidebar-overlay" class="fixed inset-0 bg-black/40 z-30"></div>

<!-- sidebar -->

<aside id="sidebar" class="w-64 bg-white border-r border-[#1a7a5e]/10 p-3 transform -translate-x-full sm:translate-x-0 transition flex flex-col overflow-hidden"
  style="height: 100%;">
  <div id="sidebar-content" class="flex-1 overflow-y-auto scroll-thin min-h-0">

<h3 id="historialTitulo" class="text-[10px] font-bold uppercase text-[#5a7a6e] px-2 pt-1 pb-3">
Historial de búsqueda
</h3>

</div>
</aside>

<!-- contenido -->

<main class="flex-1 flex flex-col chat-bg min-h-0">

<div id="chatContainer"
class="flex-1 overflow-y-auto scroll-thin px-6 py-6 flex flex-col gap-4 min-h-0">


<div class="text-center py-10 px-4 m-auto max-w-sm">

<h2 id="tituloInicio"
class="font-['Playfair_Display',serif] text-2xl text-[#135c47] mb-2">

Selecciona primero una categoría

</h2>

<p id="subtituloInicio" class="text-sm text-[#5a7a6e]">

Luego escribe el medicamento

</p>

</div>

<div class="bg-white rounded-2xl p-5 shadow-lg max-w-md">

<h3 class="font-extrabold text-[#135c47] text-base">
</h3>

<div class="grid grid-cols-2 gap-2 mt-3">

<button onclick="seleccionarFiltro('general',this)" class="filtro-btn">
📋 <span id="filtroGeneral">Info general</span>
</button>

<button onclick="seleccionarFiltro('indicaciones',this)" class="filtro-btn">
🩺 <span id="filtroIndicaciones">Indicaciones</span>
</button>

<button onclick="seleccionarFiltro('dosificacion',this)" class="filtro-btn">
💉 <span id="filtroDosificacion">Dosificación</span>
</button>

<button onclick="seleccionarFiltro('advertencias',this)" class="filtro-btn">
⚠️ <span id="filtroAdvertencias">Advertencias</span>
</button>

</div>

<button onclick="seleccionarFiltro('especial',this)"
class="filtro-btn w-full mt-2">

✨ <span id="filtroEspecial">Información especial</span>

</button>

</div>

</div>

<div id="inputContainer"
class="px-6 py-4 bg-white border-t flex gap-3">

<input
type="text"
id="medicamentoInput"
placeholder="Escribe un medicamento..."
class="flex-1 border rounded-xl px-4 py-2">

<button id="enviarBtn"
class="px-4 py-2 bg-[#1a7a5e] text-white rounded-xl">

Enviar

</button>

</div>

</main>

</div>

<script>

const idiomaUsuario = "<%= usuario.idioma %>";

const sidebar = document.getElementById('sidebar');
const overlay = document.getElementById('sidebar-overlay');

document.getElementById('sidebar-toggle').addEventListener('click', () => {

sidebar.classList.toggle('open');
overlay.classList.toggle('open');

});

overlay.addEventListener('click', () => {

sidebar.classList.remove('open');
overlay.classList.remove('open');

});

</script>

<script src="/public/js/dashboardUser.js"></script>

</body>
</html>