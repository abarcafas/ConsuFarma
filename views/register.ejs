<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MediConsulta — Crear cuenta</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/auth.css">
</head>

<body>

  <div class="card shadow card-custom text-center">

    <div class="logo-medical">
      <svg viewBox="0 0 36 36" width="36" height="36">
        <text x="18" y="16" text-anchor="middle" dominant-baseline="central" font-size="26" font-weight="800" fill="white" font-family="'Playfair Display', Georgia, serif" transform="rotate(-90, 18, 18)">M</text>
      </svg>
    </div>

    <h2 class="brand-title">MediConsulta</h2>
    <p class="text-muted mb-4">Crear cuenta</p>

    <form action="/registro" method="POST">

      <div class="row g-2 mb-3">
        <div class="col-7 text-start">
          <label class="form-label">Nombre completo</label>
          <input type="text" name="nombre" class="form-control" placeholder="Juan Pérez" required>
        </div>
        <div class="col-5 text-start">
          <label class="form-label">Edad</label>
          <input type="number" name="edad" class="form-control" placeholder="25" min="1" max="120" required>
        </div>
      </div>

      <div class="row g-2 mb-3">
        <div class="col-6 text-start">
          <label class="form-label">Género</label>
          <select name="genero" class="form-select" required>
            <option value="" disabled selected>Seleccionar</option>
            <option>Masculino</option>
            <option>Femenino</option>
            <option>Prefiero no decir</option>
          </select>
        </div>
        <div class="col-6 text-start">
          <label class="form-label">País</label>
          <select name="pais" class="form-select" required>
            <option value="" disabled selected>Seleccionar</option>
            <option>Costa Rica</option>
            <option>México</option>
            <option>Colombia</option>
            <option>Argentina</option>
            <option>España</option>
            <option>Otro</option>
          </select>
        </div>
      </div>

      <div class="mb-3 text-start">
        <label class="form-label">Idioma</label>
        <select name="idioma" class="form-select" required>
          <option value="" disabled selected>Seleccionar idioma</option>
          <option>Español</option>
          <option>English</option>
        </select>
      </div>

      <div class="mb-4 text-start">
        <label class="form-label">Contraseña</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>

      <button type="submit" class="btn btn-custom text-white w-100">
        Registrarse
      </button>

    </form>

    <p class="mt-4">
      ¿Ya tienes cuenta?
      <a href="/login" class="text-success fw-semibold text-decoration-none">
        Inicia sesión
      </a>
    </p>

  </div>

</body>
</html>
