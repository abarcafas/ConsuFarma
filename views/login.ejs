<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ConsuFarma - Login</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Fuentes del dashboard -->
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/public/css/auth.css">
</head>

<body>

  <div class="card shadow card-custom text-center">

    <!-- NUEVO LOGO IGUAL AL DASHBOARD -->
    <div class="logo-medical">
      <svg width="26" height="26" fill="white" viewBox="0 0 24 24">
        <path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zm-7 3a1 1 0 0 1 1 1v3h3a1 1 0 1 1 0 2h-3v3a1 1 0 1 1-2 0v-3H8a1 1 0 1 1 0-2h3V7a1 1 0 0 1 1-1z"/>
      </svg>
    </div>

    <!-- Título con Playfair -->
    <h2 class="brand-title">ConsuFarma</h2>
    <p class="text-muted mb-4">Iniciar sesión</p>

    <form action="/login" method="POST">

      <div class="mb-3 text-start">
        <label class="form-label">Nombre de usuario</label>
        <input type="text" name="nombre" class="form-control" placeholder="Juan Pérez" required>
      </div>

      <div class="mb-4 text-start">
        <label class="form-label">Contraseña</label>
        <input type="password" name="password" class="form-control" placeholder="********" required>
      </div>

      <button type="submit" class="btn btn-custom text-white w-100">
        Iniciar sesión
      </button>

    </form>

    <p class="mt-4">
      ¿No tienes cuenta?
      <a href="/register" class="text-success fw-semibold text-decoration-none">
        Regístrate
      </a>
    </p>

  </div>

</body>
</html>