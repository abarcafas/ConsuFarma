  </style>
  <script>
    $('#f-pais').select2({
      placeholder: 'Todos los países',
      allowClear: true,
      language: {
        noResults: () => 'No se encontró ese país'
      },
      dropdownParent: document.getElementById('filtros-bar')
    })

  </script>

</body>
